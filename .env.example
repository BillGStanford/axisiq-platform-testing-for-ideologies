# AxisIQ Environment Variables
# Copy this to .env.local and fill in values

# ─── Google Analytics 4 ─────────────────────────────────────────
# Get from: https://analytics.google.com
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# Enable/disable analytics (set to 'true' in production)
NEXT_PUBLIC_ANALYTICS_ENABLED=false

# ─── Google AdSense ──────────────────────────────────────────────
# Get from: https://www.google.com/adsense
NEXT_PUBLIC_ADSENSE_ID=ca-pub-XXXXXXXXXXXXXXXXX

# Enable/disable ads (set to 'true' in production)
NEXT_PUBLIC_ADS_ENABLED=false

# ─── Site Config ─────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://axisiq.app
